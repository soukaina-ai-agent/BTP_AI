# Chat LLM
BASE_URL=https://models.github.ai/inference
OPENAI_API_KEY=replace_with_your_token
# GitHub Models can also use GITHUB_TOKEN instead of OPENAI_API_KEY.
GITHUB_TOKEN=
MODEL=openai/gpt-4o-mini

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
USE_OPENAI_EMBEDDINGS=false
HF_TOKEN=optional_huggingface_token

# RAG
TOP_K=5

# Knowledge base
SKIP_DTU_AUTOLOAD=false

# Storage
# Local development can use relative paths.
# Railway with a mounted volume should use /data paths, or omit these and let
# the app place relative paths under RAILWAY_VOLUME_MOUNT_PATH automatically.
CHROMA_PATH=chroma_store
CHROMA_COLLECTION=btp_documents
UPLOAD_FOLDER=uploads

# OCR
# Windows example:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
OCR_LANG=fra+eng

# API / Frontend
CORS_ORIGINS=*
API_URL=http://localhost:8000

# Security
SECRET_KEY=replace_with_a_random_secret
