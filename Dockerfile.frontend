FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY frontend ./frontend

ENV PYTHONUNBUFFERED=1
ENV PORT=8080

CMD ["sh", "-c", "unset STREAMLIT_SERVER_PORT; streamlit run frontend/streamlit_app.py --server.address 0.0.0.0 --server.port ${PORT:-8080} --server.headless true"]
